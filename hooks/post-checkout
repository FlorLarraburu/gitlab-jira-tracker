#!/bin/sh
# git-jira-tracker — post-checkout hook
# This hook MUST NOT block git operations on tracker failure.
# Arguments from git: $1=prev HEAD, $2=new HEAD, $3=branch-flag (1=branch checkout)

PREV_HEAD="$1"
NEW_HEAD="$2"
BRANCH_FLAG="$3"

# Escape hatch — disable tracker without touching hooks
[ -n "$JIRA_TRACKER_DISABLED" ] && exit 0

# Only act on branch checkouts, not file checkouts
[ "$BRANCH_FLAG" = "1" ] || exit 0

# ── Locate Python ────────────────────────────────────────────────────────────
find_python() {
    # Prefer venv python set by installer
    if [ -n "$TRACKER_PYTHON" ] && [ -f "$TRACKER_PYTHON" ]; then
        echo "$TRACKER_PYTHON"
        return
    fi
    for cmd in python3 python py; do
        if command -v "$cmd" >/dev/null 2>&1; then
            echo "$cmd"
            return
        fi
    done
    # Windows: common install paths
    for path in \
        "/c/Python312/python.exe" \
        "/c/Python311/python.exe" \
        "/c/Python310/python.exe" \
        "$LOCALAPPDATA/Programs/Python/Python312/python.exe" \
        "$LOCALAPPDATA/Programs/Python/Python311/python.exe"; do
        if [ -f "$path" ]; then
            echo "$path"
            return
        fi
    done
}

PYTHON_CMD="$(find_python)"
[ -n "$PYTHON_CMD" ] || exit 0   # Python not found — skip silently

# ── Locate tracker.py ────────────────────────────────────────────────────────
# TRACKER_HOME is set by the installer; fallback to common locations
if [ -z "$TRACKER_HOME" ]; then
    REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
    for candidate in \
        "$REPO_ROOT/tracker.py" \
        "$HOME/git-jira-tracker/tracker.py" \
        "/usr/local/lib/git-jira-tracker/tracker.py"; do
        if [ -f "$candidate" ]; then
            TRACKER_HOME="$(dirname "$candidate")"
            break
        fi
    done
fi

[ -n "$TRACKER_HOME" ] && [ -f "$TRACKER_HOME/tracker.py" ] || exit 0

# ── Resolve branch names ──────────────────────────────────────────────────────
PREV_BRANCH="$(git name-rev --name-only "$PREV_HEAD" 2>/dev/null | sed 's/~[0-9]*$//' | sed 's|remotes/[^/]*/||')"
NEW_BRANCH="$(git branch --show-current 2>/dev/null)"

# ── Run tracker (errors must not propagate) ───────────────────────────────────
(
    cd "$TRACKER_HOME" || exit 0
    "$PYTHON_CMD" tracker.py _hook_checkout "$PREV_BRANCH" "$NEW_BRANCH" 2>/dev/null
) || true

exit 0
